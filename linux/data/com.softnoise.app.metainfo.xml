<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.softnoise.app</id>
  <name>SoftNoise</name>
  <summary>Microphone noise cancellation and monitor mode</summary>
  <description>
    <p>
      SoftNoise applies real-time noise cancellation to your microphone using
      RNNoise, and optionally routes the cleaned audio back to your headphones
      (monitor mode). It also provides instructions for system-wide NC via a
      PipeWire virtual sink.
    </p>
  </description>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <url type="homepage">https://github.com/qodo-ai/softnoise</url>
  <launchable type="desktop-id">com.softnoise.app.desktop</launchable>
  <provides>
    <binary>softnoise</binary>
  </provides>
  <releases>
    <release version="1.0.0" date="2026-03-12">
      <description><p>Initial Linux release.</p></description>
    </release>
  </releases>
  <content_rating type="oars-1.1"/>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
</component>
